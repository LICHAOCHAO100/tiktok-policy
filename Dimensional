<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>维度缝合 - Dimension Stitch</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Noto+Sans+SC:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-dark: #08080c;
      --bg-board: #101018;
      --neon-cyan: #00f7ff;
      --neon-pink: #ff00aa;
      --neon-yellow: #ffe600;
      --neon-green: #00ff88;
      --neon-red: #ff3355;
      --cell-bg: #18182a;
      --cell-border: #2a2a45;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      font-family: 'Noto Sans SC', sans-serif;
      background: var(--bg-dark);
      color: #fff;
      overflow: hidden;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    #game-container {
      position: relative;
      width: 100vw;
      height: 100vh;
      max-width: 450px;
      max-height: 800px;
      display: flex;
      flex-direction: column;
      padding: 20px;
    }

    /* 顶部 */
    #top-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 24px;
      background: linear-gradient(135deg, rgba(20,20,35,0.95), rgba(15,15,25,0.95));
      border-radius: 16px;
      border: 1px solid rgba(0,247,255,0.2);
      margin-bottom: 16px;
    }

    .stat-box {
      text-align: center;
    }

    .stat-label {
      font-size: 11px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 2px;
      margin-bottom: 4px;
    }

    .stat-value {
      font-family: 'Orbitron', monospace;
      font-size: 28px;
      font-weight: 800;
    }

    #score-value { color: var(--neon-cyan); text-shadow: 0 0 20px var(--neon-cyan); }
    #target-display { color: var(--neon-yellow); text-shadow: 0 0 20px var(--neon-yellow); }

    /* 棋盘 - 自适应大小 */
    #game-board {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      grid-template-rows: repeat(5, 1fr);
      gap: 8px;
      background: var(--bg-board);
      border-radius: 16px;
      padding: 16px;
      border: 1px solid rgba(0,247,255,0.15);
      min-height: 0;
    }

    .cell {
      background: var(--cell-bg);
      border: 2px solid var(--cell-border);
      border-radius: 12px;
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: 'Orbitron', monospace;
      font-size: 28px;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
      aspect-ratio: 1;
    }

    .cell:hover {
      border-color: var(--neon-cyan);
      transform: scale(1.05);
    }

    .cell.occupied {
      box-shadow: 0 0 15px currentColor, inset 0 0 15px rgba(0,0,0,0.3);
    }

    .cell.merged {
      animation: merge 0.3s ease-out;
    }

    @keyframes merge {
      0% { transform: scale(1); }
      50% { transform: scale(1.3); }
      100% { transform: scale(1); }
    }

    .cell.destroying {
      animation: destroy 0.4s ease-out forwards;
    }

    @keyframes destroy {
      0% { transform: scale(1); opacity: 1; }
      100% { transform: scale(0); opacity: 0; }
    }

    .cell.growth {
      animation: growth 0.2s ease-out;
    }

    @keyframes growth {
      0% { transform: scale(0); }
      100% { transform: scale(1); }
    }

    /* 数字颜色 */
    .cell[data-num="1"] { color: #7dd3fc; border-color: rgba(125,211,252,0.4); }
    .cell[data-num="2"] { color: #5eead4; border-color: rgba(94,234,212,0.4); }
    .cell[data-num="3"] { color: #86efac; border-color: rgba(134,239,172,0.4); }
    .cell[data-num="4"] { color: #c4b5fd; border-color: rgba(196,181,253,0.4); }
    .cell[data-num="5"] { color: #f9a8d4; border-color: rgba(249,168,212,0.4); }
    .cell[data-num="6"] { color: #fb923c; border-color: rgba(251,146,60,0.4); }
    .cell[data-num="7"] { color: #fb7185; border-color: rgba(251,113,133,0.4); }
    .cell[data-num="8"] { color: var(--neon-pink); border-color: var(--neon-pink); }
    .cell[data-num="9"] { color: var(--neon-yellow); border-color: var(--neon-yellow); }

    /* 手持区 */
    #hand-section {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 30px;
      padding: 20px;
      margin-top: 16px;
      background: linear-gradient(135deg, rgba(20,20,35,0.95), rgba(15,15,25,0.95));
      border-radius: 16px;
      border: 1px solid rgba(0,247,255,0.2);
    }

    #current-piece {
      width: 70px;
      height: 70px;
      background: var(--cell-bg);
      border: 3px solid var(--neon-cyan);
      border-radius: 14px;
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: 'Orbitron', monospace;
      font-size: 32px;
      font-weight: 900;
      box-shadow: 0 0 25px var(--neon-cyan), inset 0 0 20px rgba(0,247,255,0.1);
      cursor: pointer;
    }

    .next-box {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
    }

    .next-label {
      font-size: 10px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 2px;
    }

    #next-piece {
      width: 50px;
      height: 50px;
      background: var(--cell-bg);
      border: 2px solid var(--cell-border);
      border-radius: 10px;
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: 'Orbitron', monospace;
      font-size: 22px;
      font-weight: 700;
    }

    /* 消息 */
    #message {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-family: 'Orbitron', monospace;
      font-size: 22px;
      font-weight: 700;
      padding: 16px 32px;
      border-radius: 12px;
      opacity: 0;
      pointer-events: none;
      z-index: 20;
    }

    #message.show { opacity: 1; animation: msgPop 0.4s ease-out; }
    @keyframes msgPop {
      0% { transform: translate(-50%, -50%) scale(0.5); }
      70% { transform: translate(-50%, -50%) scale(1.1); }
      100% { transform: translate(-50%, -50%) scale(1); }
    }

    #message.success { background: rgba(0,255,136,0.9); color: #000; }
    #message.fail { background: rgba(255,51,85,0.9); color: #fff; }
    #message.bonus { background: linear-gradient(135deg, var(--neon-pink), var(--neon-yellow)); color: #000; }

    /* 玩法提示 */
    #hint {
      font-size: 12px;
      color: rgba(255,255,255,0.35);
      text-align: center;
      margin-top: 12px;
      line-height: 1.6;
    }

    /* 开始菜单 */
    #start-menu {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(8,8,12,0.98);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      z-index: 100;
      padding: 40px;
    }

    #start-menu.hidden { display: none; }

    .game-title {
      font-family: 'Orbitron', monospace;
      font-size: 36px;
      font-weight: 900;
      background: linear-gradient(135deg, var(--neon-cyan), var(--neon-pink));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 6px;
    }

    .game-subtitle {
      font-size: 13px;
      color: rgba(255,255,255,0.4);
      margin-bottom: 30px;
      letter-spacing: 6px;
    }

    .rules-box {
      background: rgba(255,255,255,0.05);
      border-radius: 16px;
      padding: 24px;
      margin-bottom: 30px;
      border: 1px solid rgba(255,255,255,0.1);
    }

    .rule-item {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
      font-size: 14px;
      color: rgba(255,255,255,0.8);
    }

    .rule-item:last-child { margin-bottom: 0; }

    .rule-icon {
      width: 36px;
      height: 36px;
      background: var(--cell-bg);
      border-radius: 10px;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 18px;
      flex-shrink: 0;
    }

    .start-btn {
      font-family: 'Orbitron', monospace;
      font-size: 16px;
      font-weight: 700;
      padding: 16px 50px;
      background: transparent;
      border: 2px solid var(--neon-cyan);
      color: var(--neon-cyan);
      cursor: pointer;
      border-radius: 12px;
      transition: all 0.3s;
    }

    .start-btn:hover {
      background: var(--neon-cyan);
      color: var(--bg-dark);
      box-shadow: 0 0 30px var(--neon-cyan);
    }

    /* 游戏结束 */
    #game-over {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(8,8,12,0.95);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      z-index: 100;
    }

    #game-over.show { display: flex; }
    #game-over:not(.show) { display: none; }

    .game-over-title {
      font-family: 'Orbitron', monospace;
      font-size: 32px;
      font-weight: 900;
      color: var(--neon-red);
      margin-bottom: 16px;
    }

    .final-score {
      font-family: 'Orbitron', monospace;
      font-size: 48px;
      font-weight: 900;
      color: var(--neon-cyan);
      margin-bottom: 30px;
    }
  </style>
</head>
<body>
  <div id="game-container">
    <div id="top-bar">
      <div class="stat-box">
        <div class="stat-label">分数</div>
        <div class="stat-value" id="score-value">0</div>
      </div>
      <div class="stat-box">
        <div class="stat-label">消除目标</div>
        <div class="stat-value" id="target-display">10</div>
      </div>
    </div>

    <div id="game-board"></div>
    <div id="message"></div>

    <div id="hand-section">
      <div class="next-box">
        <div class="next-label">NEXT</div>
        <div id="next-piece">3</div>
      </div>
      <div id="current-piece">2</div>
      <div class="next-box">
        <div class="next-label">点击</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.4)">放置</div>
      </div>
    </div>

    <div id="hint">点击空白格子放置数字，凑成10即可消除</div>

    <!-- 开始菜单 -->
    <div id="start-menu">
      <h1 class="game-title">维度缝合</h1>
      <p class="game-subtitle">DIMENSION STITCH</p>
      
      <div class="rules-box">
        <div class="rule-item">
          <div class="rule-icon">📦</div>
          <span>点击空位放置数字方块</span>
        </div>
        <div class="rule-item">
          <div class="rule-icon">🌱</div>
          <span>数字会向四周延伸（2延1格，4延2格）</span>
        </div>
        <div class="rule-item">
          <div class="rule-icon">💫</div>
          <span>相同数字相遇会合并成更大数字</span>
        </div>
        <div class="rule-item">
          <div class="rule-icon">✨</div>
          <span>行或列数字凑成10即可消除</span>
        </div>
      </div>
      
      <button class="start-btn" id="start-btn">开始游戏</button>
    </div>

    <!-- 游戏结束 -->
    <div id="game-over">
      <div class="game-over-title">游戏结束</div>
      <div class="final-score" id="final-score">0</div>
      <button class="start-btn" id="restart-btn">再来一局</button>
    </div>
  </div>

  <script>
    // ==================== 配置 ====================
    const CONFIG = {
      rows: 5,
      cols: 5,
      targetSum: 10
    };

    // ==================== 状态 ====================
    const game = {
      board: [],
      currentPiece: null,
      nextPiece: null,
      score: 0,
      gameStarted: false,
      gameOver: false,
      isProcessing: false
    };

    // ==================== DOM ====================
    const boardEl = document.getElementById('game-board');
    const currentPieceEl = document.getElementById('current-piece');
    const nextPieceEl = document.getElementById('next-piece');
    const scoreEl = document.getElementById('score-value');
    const targetEl = document.getElementById('target-display');
    const messageEl = document.getElementById('message');
    const startMenu = document.getElementById('start-menu');
    const gameOverEl = document.getElementById('game-over');
    const finalScoreEl = document.getElementById('final-score');

    // ==================== 初始化 ====================
    function initBoard() {
      boardEl.innerHTML = '';
      game.board = [];
      
      for (let r = 0; r < CONFIG.rows; r++) {
        game.board[r] = [];
        for (let c = 0; c < CONFIG.cols; c++) {
          const cell = document.createElement('div');
          cell.className = 'cell';
          cell.dataset.row = r;
          cell.dataset.col = c;
          cell.addEventListener('click', () => handleCellClick(r, c));
          boardEl.appendChild(cell);
          game.board[r][c] = { el: cell, value: null };
        }
      }
    }

    function generatePiece() {
      return Math.floor(Math.random() * 4) + 1; // 1-4
    }

    function updateHandDisplay() {
      if (game.currentPiece) {
        currentPieceEl.textContent = game.currentPiece;
        currentPieceEl.setAttribute('data-num', game.currentPiece);
      }
      if (game.nextPiece) {
        nextPieceEl.textContent = game.nextPiece;
        nextPieceEl.setAttribute('data-num', game.nextPiece);
      }
    }

    // ==================== 核心逻辑 ====================

    // 生长位置
    function getGrowthPositions(row, col, value) {
      const positions = [{ row, col }];
      const n = Math.floor(value / 2);
      
      if (n === 0) return positions;
      
      for (let i = 1; i <= n; i++) {
        if (row - i >= 0) positions.push({ row: row - i, col });
        if (row + i < CONFIG.rows) positions.push({ row: row + i, col });
        if (col - i >= 0) positions.push({ row, col: col - i });
        if (col + i < CONFIG.cols) positions.push({ row, col: col + i });
      }
      
      return positions;
    }

    // 点击放置
    function handleCellClick(row, col) {
      if (game.isProcessing || !game.gameStarted) return;
      if (game.board[row][col].value !== null) {
        showMessage('已有方块!', 'fail');
        return;
      }

      game.isProcessing = true;
      const value = game.currentPiece;
      const positions = getGrowthPositions(row, col, value);
      
      // 放置主方块
      setCellValue(row, col, value);
      
      // 生长处理
      let merged = false;
      const toMerge = [];
      
      for (let i = 1; i < positions.length; i++) {
        const pos = positions[i];
        const cell = game.board[pos.row][pos.col];
        
        if (cell.value === null) {
          // 空位 - 占据
          setCellValue(pos.row, pos.col, value, true);
        } else if (cell.value === value) {
          // 相同 - 合并
          toMerge.push(pos);
        }
        // 不同 - 阻挡
      }

      // 执行合并
      if (toMerge.length > 0) {
        const target = toMerge[0];
        const newValue = value * 2;
        
        toMerge.forEach(pos => {
          clearCell(pos.row, pos.col);
        });
        
        setCellValue(target.row, target.col, newValue, true);
        
        game.score += value * 15;
        showMessage(`${value}+${value}=${newValue}`, 'bonus');
      } else {
        game.score += value * 5;
      }

      // 切换
      game.currentPiece = game.nextPiece;
      game.nextPiece = generatePiece();
      updateHandDisplay();
      updateUI();

      // 检查消除
      setTimeout(() => checkAndClear(), 200);
    }

    function setCellValue(row, col, value, isGrowth = false) {
      const cell = game.board[row][col];
      cell.value = value;
      cell.el.textContent = value;
      cell.el.setAttribute('data-num', value > 9 ? 9 : value);
      cell.el.className = 'cell occupied' + (isGrowth ? ' growth' : '');
    }

    function clearCell(row, col) {
      const cell = game.board[row][col];
      cell.value = null;
      cell.el.textContent = '';
      cell.el.className = 'cell';
      cell.el.removeAttribute('data-num');
    }

    // 检查消除
    function checkAndClear() {
      const toDestroy = new Set();

      // 检查行
      for (let r = 0; r < CONFIG.rows; r++) {
        let sum = 0, full = true;
        for (let c = 0; c < CONFIG.cols; c++) {
          if (game.board[r][c].value === null) { full = false; break; }
          sum += game.board[r][c].value;
        }
        if (full && sum === CONFIG.targetSum) {
          for (let c = 0; c < CONFIG.cols; c++) toDestroy.add(`${r},${c}`);
        }
      }

      // 检查列
      for (let c = 0; c < CONFIG.cols; c++) {
        let sum = 0, full = true;
        for (let r = 0; r < CONFIG.rows; r++) {
          if (game.board[r][c].value === null) { full = false; break; }
          sum += game.board[r][c].value;
        }
        if (full && sum === CONFIG.targetSum) {
          for (let r = 0; r < CONFIG.rows; r++) toDestroy.add(`${r},${c}`);
        }
      }

      if (toDestroy.size > 0) {
        toDestroy.forEach(key => {
          const [r, c] = key.split(',').map(Number);
          game.board[r][c].el.classList.add('destroying');
        });

        const points = toDestroy.size * 15;
        game.score += points;
        showMessage(`✨ +${points}`, 'success');

        setTimeout(() => {
          toDestroy.forEach(key => {
            const [r, c] = key.split(',').map(Number);
            clearCell(r, c);
          });
          
          applyGravity();
          game.isProcessing = false;
          updateUI();
          
          setTimeout(() => checkAndClear(), 300);
        }, 400);
      } else {
        game.isProcessing = false;
        if (checkGameOver()) endGame();
      }
    }

    // 重力
    function applyGravity() {
      for (let c = 0; c < CONFIG.cols; c++) {
        let writeRow = CONFIG.rows - 1;
        for (let r = CONFIG.rows - 1; r >= 0; r--) {
          if (game.board[r][c].value !== null) {
            if (r !== writeRow) {
              const val = game.board[r][c].value;
              clearCell(r, c);
              setCellValue(writeRow, c, val, true);
            }
            writeRow--;
          }
        }
      }
    }

    // 游戏结束
    function checkGameOver() {
      for (let r = 0; r < CONFIG.rows; r++) {
        for (let c = 0; c < CONFIG.cols; c++) {
          if (game.board[r][c].value === null) return false;
        }
      }
      return true;
    }

    // 消息
    function showMessage(text, type) {
      messageEl.textContent = text;
      messageEl.className = type;
      messageEl.classList.add('show');
      setTimeout(() => messageEl.classList.remove('show'), 1000);
    }

    function updateUI() {
      scoreEl.textContent = game.score;
    }

    function endGame() {
      game.gameOver = true;
      game.gameStarted = false;
      finalScoreEl.textContent = game.score;
      gameOverEl.classList.add('show');
    }

    function restartGame() {
      game.board = [];
      game.currentPiece = generatePiece();
      game.nextPiece = generatePiece();
      game.score = 0;
      game.gameStarted = true;
      game.gameOver = false;
      game.isProcessing = false;
      
      initBoard();
      updateHandDisplay();
      updateUI();
      
      startMenu.classList.add('hidden');
      gameOverEl.classList.remove('show');
    }

    // 事件
    document.getElementById('start-btn').addEventListener('click', restartGame);
    document.getElementById('restart-btn').addEventListener('click', restartGame);

    initBoard();
    game.currentPiece = generatePiece();
    game.nextPiece = generatePiece();
    updateHandDisplay();
  </script>
</body>
</html>
